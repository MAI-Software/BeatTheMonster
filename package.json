{
  "name": "monsters-boxing-hero",
  "version": "0.1.0",
  "description": "JRPG rhythm-sparring brawler with camera motion combat",
  "type": "module",
  "scripts": {
    "mediapipe": "node scripts/fetch-mediapipe.mjs",
    "predev": "node scripts/fetch-mediapipe.mjs",
    "dev": "vite",
    "prebuild": "node scripts/fetch-mediapipe.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:add": "cap add android",
    "cap:sync": "npm run build && cap sync android",
    "apk": "npm run build && cap sync android && cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@resvg/resvg-js": "^2.6.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
